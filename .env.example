AUTH_SECRET=change-me-long-random
ADMIN_PASSWORD=change-me
ADMIN_EMAIL=admin@local

# PostgreSQL (Timeweb Cloud). Пароль в URL закодируй. sslrootcert — файл prisma/timeweb-ca.crt в репозитории.
# В панели Timeweb: публичный доступ + файрвол TCP 5432 (часто 0.0.0.0/0) + группа привязана к кластеру.
DATABASE_URL=

# --- S3 Timeweb (медиа). Все 6 переменных обязательны, иначе API ответит «S3 не настроен». ---
# В Vercel: Settings → Environment Variables — скопируй имена как ниже (без префикса AWS_).
#
# S3_BUCKET — имя бакета в панели Timeweb Object Storage.
# S3_ACCESS_KEY / S3_SECRET_KEY — ключи доступа к этому бакету (не путать с ключами другого сервиса).
# S3_PUBLIC_BASE_URL — базовый URL для открытия файла в браузере, без / в конце.
#   Часто: https://s3.twcstorage.ru/ИМЯ_БАКЕТА — проверь в панели раздел про публичный доступ / URL объекта.
# Для загрузки из браузера (presigned PUT) в настройках бакета нужен CORS: метод PUT, Origin = твой домен Vercel.
#
S3_ENDPOINT=https://s3.twcstorage.ru
S3_REGION=ru-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE_URL=
