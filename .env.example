AUTH_SECRET=change-me-long-random
ADMIN_PASSWORD=change-me
ADMIN_EMAIL=admin@local

# PostgreSQL (Timeweb Cloud). Пароль в URL закодируй. sslrootcert — файл prisma/timeweb-ca.crt в репозитории.
# В панели Timeweb: публичный доступ + файрвол TCP 5432 (часто 0.0.0.0/0) + группа привязана к кластеру.
DATABASE_URL=

# S3 Timeweb (медиа). Отдельный бакет под файлы приложения.
S3_ENDPOINT=https://s3.twcstorage.ru
S3_REGION=ru-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE_URL=
